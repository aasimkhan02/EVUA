{
  "description": "STRICT HTTP inline verification benchmark",

  "expected_services": 1,
  "expected_components": 5,

  "http_merge_expectations": {

    "AdminComponent": {
      "method": "load",
      "must_contain": [
        "this.http.get('/api/admin/users')",
        "this.http.get('/api/admin/roles')"
      ],
      "must_not_contain": [
        "fetchAdminUsers",
        "fetchAdminRoles"
      ]
    },

    "SettingsComponent": {
      "methods": {
        "loadSettings": [
          "this.http.get('/api/settings')"
        ],
        "loadAudit": [
          "this.http.get('/api/audit')"
        ]
      }
    },

    "SearchComponent": {
      "method": "search",
      "must_contain": [
        "this.http.get('/api/search'",
        "catchError"
      ]
    },

    "OrderComponent": {
      "methods": {
        "placeOrder": [
          "this.http.post('/api/orders'"
        ],
        "loadOrder": [
          "this.http.get('/api/orders/'"
        ]
      }
    },

    "BootstrapComponent": {
      "must_inline_top_level_http": true
    }
  },

  "forbidden_patterns": [
    "fetchUsers(",
    "fetchRoles(",
    "fetchSettings(",
    "fetchAudit(",
    "fetchSearch(",
    "fetchOrders("
  ],

  "must_import": [
    "HttpClientModule"
  ]
}