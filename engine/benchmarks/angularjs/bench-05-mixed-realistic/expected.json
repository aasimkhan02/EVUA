{
  "description": "Mixed realistic — all rule types + AppModuleUpdater + ComponentInteraction",

  "expected_classes": 6,
  "expected_services": 1,
  "expected_components": 5,

  "risk_expectations": {
    "NotificationService":   "SAFE",
    "SearchController":      "SAFE",
    "OrderController":       "MANUAL",
    "AdminController":       "SAFE",
    "ProductCardController": "SAFE",
    "DashboardController":   "SAFE"
  },

  "app_module": {
    "must_declare": [
      "AppComponent",
      "SearchComponent",
      "OrderComponent",
      "AdminComponent",
      "ProductCardComponent",
      "DashboardComponent"
    ],
    "must_provide": [
      "NotificationService"
    ],
    "must_import": [
      "BrowserModule",
      "AppRoutingModule",
      "HttpClientModule"
    ]
  },

  "component_interaction": {
    "parent": "DashboardComponent",
    "child":  "ProductCardComponent",
    "expected_inputs":  ["product"],
    "expected_outputs": ["saved"],
    "child_ts_must_contain": [
      "@Input() product",
      "@Output() saved"
    ]
  },

  "generated_files": [
    "app.module.ts",
    "search.component.ts",
    "search.component.html",
    "order.component.ts",
    "order.component.html",
    "admin.component.ts",
    "admin.component.html",
    "productcard.component.ts",
    "productcard.component.html",
    "dashboard.component.ts",
    "dashboard.component.html",
    "notification.service.ts"
  ]
}